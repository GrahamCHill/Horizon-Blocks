{
  "name": "horizon-blocks",
  "version": "1.0.0",
  "private": true,
  "description": "Modern WordPress block theme with componentized template parts and editable patterns.",
  "scripts": {
    "build:css:sass": "shx mkdir -p .tmp && sass --no-source-map resources/styles/main.scss .tmp/main.css",
    "build:css:post": "postcss .tmp/main.css -o assets/css/main.css",
    "build:css": "run-s build:css:sass build:css:post",
    "build:js": "esbuild resources/scripts/main.ts --bundle --format=iife --target=es2018 --outfile=assets/js/main.js",
    "build:clean": "shx rm -rf .tmp",
    "build": "run-s build:css build:js",
    "build:prod": "run-s build build:clean",
    "dev:css": "sass --watch resources/styles/main.scss:assets/css/main.css",
    "dev:js": "esbuild resources/scripts/main.ts --bundle --format=iife --target=es2018 --outfile=assets/js/main.js --watch",
    "dev": "run-p dev:css dev:js"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.3",
    "postcss-cli": "^11.0.1",
    "sass": "^1.86.0",
    "shx": "^0.4.0",
    "typescript": "^5.8.2"
  }
}
