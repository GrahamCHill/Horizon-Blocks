{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "color": {
      "defaultPalette": false,
      "palette": [
        {
          "slug": "base",
          "name": "Base",
          "color": "#f7f4ee"
        },
        {
          "slug": "contrast",
          "name": "Contrast",
          "color": "#1b1f1e"
        },
        {
          "slug": "primary",
          "name": "Primary",
          "color": "#0f766e"
        },
        {
          "slug": "secondary",
          "name": "Secondary",
          "color": "#d97706"
        },
        {
          "slug": "muted",
          "name": "Muted",
          "color": "#6b7280"
        },
        {
          "slug": "surface",
          "name": "Surface",
          "color": "#fffdf8"
        }
      ]
    },
    "layout": {
      "contentSize": "760px",
      "wideSize": "1240px"
    },
    "spacing": {
      "blockGap": true,
      "margin": true,
      "padding": true
    },
    "typography": {
      "dropCap": false,
      "fluid": true,
      "fontFamilies": [
        {
          "fontFamily": "\"DM Sans\", sans-serif",
          "name": "DM Sans",
          "slug": "body"
        },
        {
          "fontFamily": "\"Cormorant Garamond\", serif",
          "name": "Cormorant Garamond",
          "slug": "display"
        }
      ],
      "fontSizes": [
        {
          "slug": "small",
          "name": "Small",
          "size": "0.95rem"
        },
        {
          "slug": "medium",
          "name": "Medium",
          "size": "1.125rem"
        },
        {
          "slug": "large",
          "name": "Large",
          "size": "1.5rem"
        },
        {
          "slug": "x-large",
          "name": "XL",
          "size": "clamp(2.5rem, 6vw, 5rem)"
        }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--base)",
      "text": "var(--wp--preset--color--contrast)"
    },
    "elements": {
      "button": {
        "border": {
          "radius": "999px"
        },
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text": "#ffffff"
        }
      },
      "heading": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--display)",
          "fontWeight": "600",
          "lineHeight": "1.05"
        }
      }
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--body)",
      "fontSize": "1rem",
      "lineHeight": "1.7"
    }
  },
  "templateParts": [
    {
      "name": "header",
      "title": "Header",
      "area": "header"
    },
    {
      "name": "footer",
      "title": "Footer",
      "area": "footer"
    }
  ]
}
